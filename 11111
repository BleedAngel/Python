#include <bits/stdc++.h>
using namespace std;

int main() {
    int k,q,r;
    cin>>k>>q>>r;
    string s,ans;
    getline(cin,s);
    for(int i=0;i<q;i++){
        string x;
        getline(cin,x);
        stringstream xx(x);
        vector<int> line;
        int num;
        while(xx>>num){
            line.push_back(num);
        }
        string ss=s;
        for(int j=0;j<k;j++){
            ss[line[j]]=s[j];
        }
        s=ss;
        ans+=s[r-1];
    }
    cout<<ans;
}
